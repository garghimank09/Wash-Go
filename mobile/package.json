{
  "name": "mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "prestart": "node scripts/prewarm-dev.js",
    "start": "expo start",
    "start:clear": "expo start -c",
    "start:fast": "node scripts/prewarm-dev.js && expo start",
    "start:sim": "expo start --ios",
    "start:device": "node scripts/start-device.js",
    "start:device:clear": "node scripts/start-device.js --clear",
    "start:tunnel": "npx expo start --tunnel",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "web": "expo start --web",
    "start:reset": "watchman watch-del-all 2>/dev/null; watchman watch . 2>/dev/null; expo start -c",
    "kill-metro": "lsof -ti:8081 | xargs kill -9 2>/dev/null || true",
    "clean:modules": "node scripts/clean-node-modules.js",
    "reinstall": "npm run clean:modules && rm -rf .expo && npm install",
    "postinstall": "node scripts/verify-deps.js",
    "verify-deps:full": "node scripts/verify-deps-full.js",
    "fix:watchman": "watchman watch-del-all 2>/dev/null; watchman watch-project ."
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-navigation/bottom-tabs": "^7.16.1",
    "@react-navigation/drawer": "^7.10.2",
    "@react-navigation/native": "^7.2.4",
    "expo": "~55.0.25",
    "expo-blur": "~55.0.14",
    "expo-constants": "~55.0.16",
    "expo-file-system": "~55.0.21",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.10",
    "expo-image-manipulator": "~55.0.16",
    "expo-image-picker": "~55.0.20",
    "expo-linear-gradient": "~55.0.14",
    "expo-linking": "~55.0.15",
    "expo-location": "~55.1.10",
    "expo-router": "~55.0.16",
    "expo-secure-store": "~55.0.14",
    "expo-splash-screen": "~55.0.21",
    "expo-status-bar": "~55.0.6",
    "lucide-react-native": "^1.16.0",
    "moti": "^0.30.0",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-maps": "1.27.2",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-worklets": "0.7.4"
  },
  "private": true,
  "devDependencies": {
    "babel-preset-expo": "^55.0.21"
  }
}
