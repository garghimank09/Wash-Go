# Copy to .env — only needed if defaults are wrong for your setup.
#
# iOS Simulator (default in apiConfig.js): http://127.0.0.1:8001
# Physical phone on same Wi‑Fi: http://YOUR_MAC_LAN_IP:8001
# Android Emulator: http://10.0.2.2:8001
#
# WashGo uses port 8001 by default (8000 is often used by other local apps).
#
# EXPO_PUBLIC_API_URL=http://192.168.1.9:8001
#
# ─── Google Maps (required for map tiles on Android) ─────────────────────────
# Custom keys do NOT work in Expo Go. Use a development build:
#   cd mobile && npm run android
#
# Google Cloud Console checklist:
#   1. Enable "Maps SDK for Android" (and iOS if needed)
#   2. Enable billing on the project
#   3. Create an API key; restrict to Android app:
#      - Package name: com.washgo.mobile
#      - SHA-1: debug keystore from first native build:
#          cd mobile && npx expo run:android
#          cd android && ./gradlew signingReport
#        (use the debug variant SHA-1)
#   4. Use an Android emulator with "Google Play" system image (not AOSP-only)
#
# After changing the key, rebuild — do not only reload Metro.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
